# Local Docker Postgres database
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/parti_design_local

# Used to encrypt JWT tokens
PAYLOAD_SECRET=change-me

# Public URL of the local app. No trailing slash.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Directory where uploaded media files are stored.
# Leave unset in development to use public/media in the project root.
UPLOAD_DIR=

# Secret used to authenticate cron jobs
CRON_SECRET=change-me

# Used to validate preview requests
PREVIEW_SECRET=change-me
