# PostgreSQL connection string (injected automatically by Coolify in production)
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/parti-design

# Used to encrypt JWT tokens — generate with: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public URL of the site. No trailing slash.
# In Coolify, set this to your production domain e.g. https://parti.design
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Directory where uploaded media files are stored.
# In Coolify, set to the mounted Hetzner volume path: /app/public/media
# Leave unset in development (defaults to public/media in the project root)
UPLOAD_DIR=

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
